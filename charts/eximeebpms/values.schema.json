{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["image", "service", "database"],
  "properties": {
    "general": {
      "type": "object",
      "properties": {
        "debug": { "type": "boolean" },
        "replicaCount": { "type": "integer", "minimum": 0 },
        "nameOverride": { "type": "string" },
        "fullnameOverride": { "type": "string" }
      }
    },
    "image": {
      "type": "object",
      "required": ["repository"],
      "properties": {
        "repository": { "type": "string" },
        "tag": { "type": "string" },
        "pullPolicy": { "type": "string", "enum": ["Always", "IfNotPresent", "Never"] },
        "pullSecrets": { "type": "array" },
        "command": { "type": "array" },
        "args": { "type": "array" }
      }
    },
    "persistence": {
      "type": "object",
      "properties": {
        "storageClass": { "type": "string" },
        "size": { "type": "string" }
      }
    },
    "database": {
      "type": "object",
      "required": ["driver", "url"],
      "properties": {
        "driver": { "type": "string" },
        "url": { "type": "string" },
        "credentialsSecretEnabled": { "type": "boolean" },
        "credentialsSecretName": { "type": "string" },
        "credentialsSecretKeys": {
          "type": "object",
          "properties": {
            "username": { "type": "string" },
            "password": { "type": "string" }
          }
        }
      }
    },
    "service": {
      "type": "object",
      "required": ["port"],
      "properties": {
        "enabled": { "type": "boolean" },
        "annotations": { "type": "object" },
        "port": { "type": "integer" },
        "portName": { "type": "string" },
        "protocol": { "type": "string" },
        "type": { "type": "string", "enum": ["ClusterIP", "NodePort", "LoadBalancer"] },
        "nodePort": { "type": "integer" },
        "loadBalancerIP": { "type": "string" }
      }
    },
    "metrics": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "service": { "type": "object" }
      }
    },
    "serviceAccount": {
      "type": "object",
      "properties": {
        "create": { "type": "boolean" },
        "annotations": { "type": "object" },
        "name": { "type": "string" }
      }
    },
    "startupProbe": { "type": "object" },
    "readinessProbe": { "type": "object" },
    "livenessProbe": { "type": "object" },
    "ingress": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "annotations": { "type": "object" },
        "hosts": { "type": "array" },
        "tls": { "type": "array" }
      }
    },
    "recreatePods": { "type": "boolean" },
    "podAnnotations": { "type": "object" },
    "podSecurityContext": { "type": "object" },
    "securityContext": {
      "type": "object",
      "properties": {
        "runAsNonRoot": { "type": "boolean" },
        "runAsUser": { "type": "integer" },
        "allowPrivilegeEscalation": { "type": "boolean" },
        "readOnlyRootFilesystem": { "type": "boolean" },
        "capabilities": { "type": "object" },
        "seccompProfile": { "type": "object" }
      }
    },
    "resources": { "type": "object" },
    "extraVolumeMounts": { "type": "array" },
    "extraVolumes": { "type": "array" },
    "extraEnvs": { "type": "array" },
    "extraContainers": { "type": "array" },
    "initContainers": { "type": "array" },
    "autoscaling": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "minReplicas": { "type": "integer" },
        "maxReplicas": { "type": "integer" },
        "cpuUtilizationPercentage": { "type": "integer" },
        "memoryUtilizationPercentage": { "type": "integer" }
      }
    },
    "podDisruptionBudget": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "minAvailable": { "type": ["integer", "string"] },
        "maxUnavailable": { "type": ["integer", "string"] }
      }
    },
    "networkPolicy": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "ingress": { "type": "array" },
        "egress": { "type": "array" }
      }
    },
    "nodeSelector": { "type": "object" },
    "tolerations": { "type": "array" },
    "affinity": { "type": "object" },
    "annotations": { "type": "object" },
    "commonLabels": { "type": "object" },
    "tests": { "type": "object" }
  }
}
